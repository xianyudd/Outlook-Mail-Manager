# 服务端口
PORT=3000

# 日志级别
LOG_LEVEL=info

# 日志目录（相对于 server/）
LOG_DIR=./data/logs

# 数据库路径（相对于 server/）
DB_PATH=./data/outlook.db

# 访问密码（留空则不启用认证）
ACCESS_PASSWORD=

# Feature Flags
MAIL_FETCH_ENABLED=true
MAIL_CLEAR_REMOTE_ENABLED=false
BULK_PULL_ENABLED=true
READ_ONLY_MODE=false
DEBUG_LOG_ENABLED=false
